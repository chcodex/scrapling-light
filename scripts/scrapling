#!/bin/bash
set -euo pipefail

MCP_BACKEND="scrapling"

# ── Helpers ──

write_and_report() {
    local content="$1" output_path="$2" url="$3" status="$4"
    if [ -z "$content" ]; then
        echo "✗ $url → $output_path (skipped, empty content, status=${status})"
        return 1
    fi
    mkdir -p "$(dirname "$output_path")"
    printf '%s' "$content" > "$output_path"
    local size
    size=$(wc -c < "$output_path" 2>/dev/null || echo "0")
    echo "✓ $url → $output_path (${size}B, ${status})"
}

write_mcp_result() {
    local json="$1" output_path="$2"
    local url status content
    url=$(printf '%s' "$json" | jq -r '.url // "unknown"')
    status=$(printf '%s' "$json" | jq -r '.status // "?"')
    content=$(printf '%s' "$json" | jq -j '(.content // .) | if type == "array" then join("") else tostring end')
    write_and_report "$content" "$output_path" "$url" "$status"
}

url_to_filename() {
    local url="$1" ext="${2:-.md}"
    local name
    name=$(printf '%s' "$url" | sed 's#/$##' | awk -F/ '{print $NF}')
    [ -z "$name" ] && name="index"
    name="${name%%\?*}"
    echo "${name}${ext}"
}

pick_extraction_type() {
    case "$1" in
        *.md|*.markdown) echo "markdown" ;;
        *.html|*.htm)    echo "html" ;;
        *.txt)           echo "text" ;;
        *)               echo "" ;;
    esac
}

# ── Screenshot (unchanged) ──

screenshot_output() {
    local raw mod
    raw="$(cat)"
    if printf '%s' "$raw" | jq -e . >/dev/null 2>&1; then
        raw="$(printf '%s' "$raw" | jq -r '(.content // .) | if type == "array" then join("") else tostring end')"
    else
        raw="${raw%%$'\n'*}"
    fi
    [ -n "$raw" ] || return 1
    mod=$(( ${#raw} % 4 ))
    if [ "$mod" -ne 0 ]; then
        raw+="$(printf '%*s' $((4 - mod)) '' | tr ' ' '=')"
    fi
    printf '%s' "$raw" | base64 -d
}

# ── Arg translation (unchanged) ──

TRANSLATED=()
TRANSLATE_CMD=""
translate_args() {
    TRANSLATED=()
    local skip_next=false
    for ((i=1; i<=$#; i++)); do
        if $skip_next; then skip_next=false; continue; fi
        case "${!i}" in
            --ai-targeted)       TRANSLATED+=("--main-content-only") ;;
            --no-headless|--enable-resources|--no-network-idle) ;;
            --no-real-chrome|--allow-webrtc|--no-solve-cloudflare) ;;
            --block-webgl|--show-canvas) ;;
            --no-follow-redirects) TRANSLATED+=("--follow-redirects" "false") ;;
            --no-verify)          TRANSLATED+=("--verify" "false") ;;
            --no-stealthy-headers) TRANSLATED+=("--stealthy-headers" "false") ;;
            --no-dns-over-https) TRANSLATED+=("--dns-over-https" "false") ;;
            --no-block-ads)      TRANSLATED+=("--block-ads" "false") ;;
            -H)
                local ni=$((i+1))
                if [ $ni -le $# ]; then
                    local hval="${!ni}"
                    local hk="${hval%%:*}"
                    local hv="${hval#*: }"
                    hv="${hv#"${hv%%[! ]*}"}"
                    case "${TRANSLATE_CMD:-get}" in
                        fetch|stealthy-fetch|bulk-fetch|bulk-stealthy-fetch)
                            TRANSLATED+=("--extra-headers" "{\"$hk\":\"$hv\"}") ;;
                        *) TRANSLATED+=("--headers" "{\"$hk\":\"$hv\"}") ;;
                    esac
                    skip_next=true
                fi ;;
            -s)
                local ni=$((i+1))
                if [ $ni -le $# ]; then
                    TRANSLATED+=("--css-selector" "${!ni}"); skip_next=true
                fi ;;
            -p)
                local ni=$((i+1))
                if [ $ni -le $# ]; then
                    local val="${!ni}" k="${val%%=*}" v="${val#*=}"
                    TRANSLATED+=("--params" "{\"$k\":\"$v\"}"); skip_next=true
                fi ;;
            -d)
                local ni=$((i+1))
                if [ $ni -le $# ]; then
                    TRANSLATED+=("--data" "${!ni}"); skip_next=true
                fi ;;
            -j)
                local ni=$((i+1))
                if [ $ni -le $# ]; then
                    TRANSLATED+=("--json" "${!ni}"); skip_next=true
                fi ;;
            --cookies)
                local ni=$((i+1))
                if [ $ni -le $# ]; then
                    local c="${!ni}" json="{"; local first=true
                    IFS=';' read -ra pairs <<< "$c"
                    for pair in "${pairs[@]}"; do
                        pair="${pair#"${pair%%[! ]*}"}"
                        pair="${pair%"${pair##*[! ]}"}"
                        [ -z "$pair" ] && continue
                        local ck="${pair%%=*}" cv="${pair#*=}"
                        $first || json+=","; first=false
                        json+="\"$ck\":\"$cv\""
                    done
                    json+="}"
                    TRANSLATED+=("--cookies" "$json"); skip_next=true
                fi ;;
            --params)
                local ni=$((i+1))
                if [ $ni -le $# ]; then
                    local pv="${!ni}"
                    if [[ "$pv" != \{* ]]; then
                        local pk="${pv%%=*}" pv2="${pv#*=}"
                        TRANSLATED+=("--params" "{\"$pk\":\"$pv2\"}")
                    else
                        TRANSLATED+=("--params" "$pv")
                    fi
                    skip_next=true
                fi ;;
            *)  TRANSLATED+=("${!i}") ;;
        esac
    done
}

is_extract_cmd() {
    case "$1" in get|fetch|stealthy-fetch|bulk-get|bulk-fetch|bulk-stealthy-fetch) return 0 ;; esac
    return 1
}

# ── Main ──

main() {
    local CMD="" URL="" OUTPUT="" EXTRACTION_TYPE="" SESSION_ID=""
    local IS_BULK=false IS_SESSION=false IS_SCREENSHOT=false
    local MCP_ARGS=() MCP_CMD_OVERRIDE=""

    if [ "${1:-}" = "extract" ]; then shift; fi

    CMD="${1:-}"
    case "$CMD" in
        -h|--help|help)
            echo "Usage: scrapling [extract] <command> [options]"
            echo
            echo "Commands:"
            echo "  get              Static GET request"
            echo "  fetch            Browser fetch (JS rendering)"
            echo "  stealthy-fetch   Stealth browser fetch (anti-bot)"
            echo "  bulk-get         Static GET for multiple URLs"
            echo "  bulk-fetch       Browser fetch for multiple URLs"
            echo "  bulk-stealthy-fetch  Stealth browser for multiple URLs"
            echo "  session          Browser session management"
            echo "  screenshot       Capture page screenshot"
            echo
            echo "See 'scrapling <command> --help' for per-command options."
            exit 0 ;;
    esac

    [ -n "$CMD" ] || { echo "Usage: scrapling [extract] <command> ..."; exit 2; }
    shift

    case "$CMD" in
        session)
            IS_SESSION=true
            local sub="${1:-}"
            local sub_lower="${sub,,}"
            if [ -z "$sub" ] || [ "$sub_lower" = "--help" ] || [ "$sub_lower" = "-h" ]; then
                echo "Usage: scrapling session <subcommand> [options]"
                echo ""
                echo "Subcommands:"
                echo "  open   Open a browser session"
                echo "  close  Close a session (requires <session-id>)"
                echo "  list   List all open sessions"
                echo ""
                echo "See 'scrapling session <subcommand> --help' for details."
                exit 0
            fi
            shift
            case "$sub" in
                open)  MCP_CMD_OVERRIDE="open-session" ;;
                close) MCP_CMD_OVERRIDE="close-session"
                       local close_first="${1:-}"; close_first="${close_first,,}"
                       if [ "$close_first" = "--help" ] || [ "$close_first" = "-h" ]; then
                           : # let --help flow to MCP_ARGS
                       else
                           SESSION_ID="${1:-}"; [ -n "$SESSION_ID" ] || { echo "Usage: scrapling session close <session-id>"; exit 2; }
                           shift
                       fi ;;
                list)  MCP_CMD_OVERRIDE="list-sessions" ;;
                *)     echo "Unknown session subcommand: $sub"; exit 2 ;;
            esac
            ;;
        screenshot)
            IS_SCREENSHOT=true
            if [ -n "${1:-}" ] && [[ "$1" == -* ]]; then
                URL=""
            else
                URL="${1:-}"; [ -n "$URL" ] || { echo "Usage: scrapling screenshot <url> [output.png] [options]"; exit 2; }
                shift
            fi
            if [ -n "${1:-}" ] && [[ "$1" != -* ]]; then
                OUTPUT="$1"; shift
            fi
            ;;
        bulk-get|bulk-fetch|bulk-stealthy-fetch)
            IS_BULK=true
            local bulk_first="${1:-}"; bulk_first="${bulk_first,,}"
            if [ "$bulk_first" = "--help" ] || [ "$bulk_first" = "-h" ]; then
                OUTPUT="/dev/null"
            else
                OUTPUT="${1:-}"; [ -n "$OUTPUT" ] || { echo "Usage: scrapling $CMD <output> <url1> <url2> ... [options]"; exit 2; }
                shift
            fi
            # For single-file merge mode, detect extraction type from extension
            if [ -d "$OUTPUT" ] || [ "${OUTPUT: -1}" = "/" ]; then
                :
            else
                local et; et=$(pick_extraction_type "$OUTPUT")
                [ -n "$et" ] && EXTRACTION_TYPE="$et"
            fi
            ;;
        get|fetch|stealthy-fetch)
            if [ -n "${1:-}" ] && [[ "$1" == -* ]]; then
                URL=""
            else
                URL="${1:-}"; [ -n "$URL" ] || { echo "Usage: scrapling $CMD <url> [output] [options]"; exit 2; }
                shift
            fi
            if [ -n "${1:-}" ] && [[ "$1" != -* ]]; then
                OUTPUT="$1"
                local et; et=$(pick_extraction_type "$OUTPUT")
                [ -n "$et" ] && EXTRACTION_TYPE="$et"
                shift
            fi
            ;;
        *)
            echo "Unknown command: $CMD"
            echo "Commands: get, fetch, stealthy-fetch, bulk-get, bulk-fetch, bulk-stealthy-fetch, session, screenshot"
            exit 2 ;;
    esac

    MCP_ARGS=("$@")

    local CMD_NAME="$CMD"
    if $IS_SESSION; then
        CMD_NAME="$MCP_CMD_OVERRIDE"
    elif $IS_SCREENSHOT; then
        CMD_NAME="screenshot"
    fi

    local MCP_CMD=(mcp2cli @"$MCP_BACKEND" "$CMD_NAME")

    if [ -n "$URL" ]; then
        MCP_CMD+=(--url "$URL")
    fi
    if [ -n "$SESSION_ID" ]; then
        MCP_CMD+=(--session-id "$SESSION_ID")
    fi

    # Bulk: build --urls JSON array
    if $IS_BULK; then
        local urls_json="[" first=true
        for arg in "$@"; do
            [[ "$arg" == -* ]] && break
            $first || urls_json+=","
            first=false
            urls_json+="\"$arg\""
        done
        urls_json+="]"
        MCP_CMD+=(--urls "$urls_json")

        MCP_ARGS=()
        local consume=true
        for arg in "$@"; do
            if $consume && [[ "$arg" != -* ]]; then continue; fi
            consume=false; MCP_ARGS+=("$arg")
        done
    fi

    if [ -n "$EXTRACTION_TYPE" ]; then
        MCP_CMD+=(--extraction-type "$EXTRACTION_TYPE")
    else
        # Default to markdown for bulk commands and single URL without explicit output
        MCP_CMD+=(--extraction-type "markdown")
    fi

    if [ ${#MCP_ARGS[@]} -gt 0 ]; then
        TRANSLATE_CMD="$CMD"
        translate_args "${MCP_ARGS[@]}"
        MCP_CMD+=("${TRANSLATED[@]}")
    fi

    # Detect --help / -h in args: bypass pipeline, show filtered help + wrapper info
    for arg in "${MCP_ARGS[@]}"; do
        local arg_lower="${arg,,}"
        if [[ "$arg_lower" == "--help" || "$arg_lower" == "-h" ]]; then
            # Build clean help command (ignore user's args, always pass --help)
            local help_cmd=(mcp2cli @"$MCP_BACKEND" "$CMD_NAME" --help)
            set +e
            "${help_cmd[@]}" 2>/dev/null | sed -e 's/mcp2cli/scrapling/g' \
                -e 's/open-session/session open/g' \
                -e 's/close-session/session close/g' \
                -e 's/list-sessions/session list/g' || true
            set -e
            echo ""
            if $IS_BULK; then
                echo "--- scrapling wrapper ---"
                echo "Output modes:"
                echo "  <path/>  Directory: auto-named files per URL"
                echo "  <file>   Merge: all content with '## URL:' headers"
                echo "Feedback: '✓ <url> → <path> (<size>B, <status>)'"
                echo "Summary:  '--- Done: N URLs, M succeeded, K skipped ---'"
            elif ! $IS_SESSION && ! $IS_SCREENSHOT; then
                echo "--- scrapling wrapper ---"
                echo "Feedback: '✓ <url> → <path> (<size>B, <status>)'"
                echo "No output path: content to stdout, feedback to stderr"
            fi
            echo "Empty content skipped, no empty files created."
            exit 0
        fi
    done

    # ── Execute ──

    if $IS_SCREENSHOT; then
        if [ -n "$OUTPUT" ]; then
            "${MCP_CMD[@]}" 2>/dev/null | screenshot_output > "$OUTPUT"
        else
            "${MCP_CMD[@]}" 2>/dev/null | screenshot_output
        fi
    elif is_extract_cmd "$CMD"; then
        local tmpfile; tmpfile=$(mktemp)
        set +e
        "${MCP_CMD[@]}" 2>/dev/null > "$tmpfile"
        local mcp_exit=$?
        set -e

        if [ $mcp_exit -ne 0 ] && [ ! -s "$tmpfile" ]; then
            echo "✗ MCP command failed (exit=$mcp_exit)"
            rm -f "$tmpfile"
            exit $mcp_exit
        fi

        if $IS_BULK; then
            local is_dir=false
            if [ -d "$OUTPUT" ] || [ "${OUTPUT: -1}" = "/" ]; then
                is_dir=true
                mkdir -p "$OUTPUT"
            fi

            local count=0 success=0 skip=0
            while IFS= read -r line; do
                case "$line" in
                    \{*) ;;
                    "") continue ;;
                    *) continue ;;
                esac
                count=$((count + 1))
                local url status content
                url=$(printf '%s' "$line" | jq -r '.url // "unknown"')
                status=$(printf '%s' "$line" | jq -r '.status // "?"')
                content=$(printf '%s' "$line" | jq -j '(.content // .) | if type == "array" then join("") else tostring end')

                if $is_dir; then
                    local fname; fname=$(url_to_filename "$url" ".md")
                    local fpath="${OUTPUT%/}/${fname}"
                    write_and_report "$content" "$fpath" "$url" "$status" && success=$((success + 1)) || skip=$((skip + 1))
                else
                    if [ $count -eq 1 ]; then
                        printf '## URL: %s (status=%s)\n\n%s\n' "$url" "$status" "$content" > "$OUTPUT"
                    else
                        printf '\n\n## URL: %s (status=%s)\n\n%s\n' "$url" "$status" "$content" >> "$OUTPUT"
                    fi
                    local fsize; fsize=$(wc -c < "$OUTPUT" 2>/dev/null || echo "0")
                    echo "✓ $url → $OUTPUT (${fsize}B cumulative, ${status})"
                    success=$((success + 1))
                fi
            done < <(jq -c '.' "$tmpfile" 2>/dev/null || true)
            rm -f "$tmpfile"

            if [ "$count" -eq 0 ]; then
                echo "✗ No results returned from MCP"
            else
                echo "--- Done: $count URLs, $success succeeded, $skip skipped ---"
            fi
        else
            # Single URL
            if [ -n "$OUTPUT" ]; then
                write_mcp_result "$(cat "$tmpfile")" "$OUTPUT"
            else
                # No output file → stdout (raw content only)
                local url status content
                url=$(jq -r '.url // "unknown"' "$tmpfile")
                status=$(jq -r '.status // "?"' "$tmpfile")
                jq -j '(.content // .) | if type == "array" then join("") else tostring end' "$tmpfile"
                echo "✓ $url → stdout (${status})" >&2
            fi
            rm -f "$tmpfile"
        fi
    else
        # Session
        if [ -n "$OUTPUT" ]; then
            "${MCP_CMD[@]}" 2>/dev/null > "$OUTPUT"
        else
            "${MCP_CMD[@]}" 2>/dev/null
        fi
    fi
}

main "$@"
